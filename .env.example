# ============================================================
# GYMTRACKER — Environment Variables
# ============================================================
# 1. Copy this file: cp .env.example .env.local
# 2. Fill in your values from Supabase Dashboard → Settings → API
# 3. NEVER commit .env.local to git
# ============================================================

# Supabase (from: Dashboard → Settings → API)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-key-here

# Stripe (from: Stripe Dashboard → Products → Prices)
VITE_STRIPE_PRO_PRICE_ID=price_xxxxx
VITE_STRIPE_UNLIMITED_PRICE_ID=price_yyyyy
